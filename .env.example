# ============================================
# DOIS LADOS - Variáveis de Ambiente
# ============================================
# Copie este ficheiro para .env e preencha
# ============================================

# ------------------------------
# Flask
# ------------------------------
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=gerar-uma-chave-secreta-unica-aqui-min-32-caracteres
CORS_ORIGINS=*

# ------------------------------
# Frontend Vercel
# ------------------------------
VITE_API_URL=https://twolados.onrender.com

# ------------------------------
# Base de Dados MySQL Aiven
# ------------------------------
MYSQL_USER=avnadmin
MYSQL_PASSWORD=sua-password-aiven
MYSQL_HOST=seu-host-aiven.aivencloud.com
MYSQL_PORT=23198
MYSQL_DB=defaultdb

# ------------------------------
# E-mail (SMTP do dominio)
# ------------------------------
# IMAP/POP3 recebem email. O site envia email usando SMTP.
# Use a configuracao segura SSL/TLS do painel do email.
# 2. Ative 2FA (Autenticação em 2 fatores)
# ------------------------------
MAIL_SERVER=mail.doislados.ao
MAIL_PORT=465
MAIL_USE_TLS=False
MAIL_USE_SSL=True
MAIL_USERNAME=geral@doislados.ao
MAIL_PASSWORD="sua-senha-do-email-aqui"
MAIL_TIMEOUT=10
MAIL_DEFAULT_SENDER=geral@doislados.ao
SUBMISSION_EMAIL=geral@doislados.ao
ADMIN_EMAIL=geral@doislados.ao
APPLICATION_EMAIL=geral@doislados.ao
CONTACT_EMAIL=geral@doislados.ao

# ------------------------------
# Upload de Ficheiros
# ------------------------------
UPLOAD_FOLDER=/caminho/absoluto/para/static/uploads
MAX_CONTENT_LENGTH=16777216
