# ------------------------------
# E-mail (Gmail SMTP)
# ------------------------------
# IMPORTANTE: Para Gmail, precisa gerar uma "App Password"
# 1. Aceda a: https://myaccount.google.com/security
# 2. Ative 2FA (Autenticação em 2 fatores)
# 3. Aceda a: https://myaccount.google.com/apppasswords
# 4. Gere uma nova App Password (16 caracteres)
# 5. Cole abaixo
# ------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=geral@doislados.ao
