# ============================================
# DOIS LADOS - Variáveis de Ambiente
# ============================================
# Copie este ficheiro para .env e preencha
# ============================================

# ------------------------------
# Flask
# ------------------------------
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=gerar-uma-chave-secreta-unica-aqui-min-32-caracteres

# ------------------------------
# Base de Dados MySQL
# ------------------------------
DATABASE_URL=mysql+pymysql://root:sua_password@localhost:3306/dois_lados?charset=utf8mb4

# ------------------------------
# E-mail (Gmail SMTP)
# ------------------------------
# IMPORTANTE: Para Gmail, precisa gerar uma "App Password"
# 1. Aceda a: https://myaccount.google.com/security
# 2. Ative 2FA (Autenticação em 2 fatores)
# 3. Aceda a: https://myaccount.google.com/apppasswords
# 4. Gere uma nova App Password (16 caracteres)
# 5. Cole abaixo
# ------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=nelsonbambi177@gmail.com
MAIL_PASSWORD=sua-app-password-do-gmail-aqui
ADMIN_EMAIL=nelsonbambi177@gmail.com

# ------------------------------
# Upload de Ficheiros
# ------------------------------
UPLOAD_FOLDER=/caminho/absoluto/para/static/uploads
MAX_CONTENT_LENGTH=16777216
