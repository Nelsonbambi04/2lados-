# ============================================================
# DOIS LADOS - CONFIGURAÇÃO DE AMBIENTE
# ============================================================
# Copie este ficheiro para .env e preencha os valores
# ============================================================

# ════════════════════════════════════════════════════════════
# BASE DE DADOS
# ════════════════════════════════════════════════════════════

# MySQL Aiven
MYSQL_USER=avnadmin
MYSQL_PASSWORD=sua-password-aiven
MYSQL_HOST=seu-host-aiven.aivencloud.com
MYSQL_PORT=23198
MYSQL_DB=defaultdb


# PostgreSQL (produção)

# ════════════════════════════════════════════════════════════
# SEGURANÇA
# ════════════════════════════════════════════════════════════

# Chave secreta para sessões (gere uma única para produção)
# Gere em: https://randomkeygen.com/
SECRET_KEY=sua-chave-secreta-muito-longa-e-aleatoria-aqui
CORS_ORIGINS=*

# ════════════════════════════════════════════════════════════
# SERVIDOR
# ════════════════════════════════════════════════════════════

# Porto da aplicação
PORT=5000

# Ambiente (development / production)
FLASK_ENV=development

# Host (0.0.0.0 para aceitar conexões externas)
FLASK_HOST=0.0.0.0

# ════════════════════════════════════════════════════════════
# EMAIL (FLASK-MAIL)
# ════════════════════════════════════════════════════════════

# Servidor SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true

# Credenciais (use App Password do Google, não a password normal)
MAIL_USERNAME=geral@doislados.ao
MAIL_PASSWORD=sua_app_password_de_16_caracteres

# Email padrão para envio
MAIL_DEFAULT_SENDER=geral@doislados.ao

# Email do administrador (recebe notificações)
SUBMISSION_EMAIL=geral@doislados.ao
ADMIN_EMAIL=geral@doislados.ao
APPLICATION_EMAIL=geral@doislados.ao
CONTACT_EMAIL=geral@doislados.ao
ADMIN_NAME=Dois Lados Admin

# ════════════════════════════════════════════════════════════
# CORS (Para integração com React)
# ════════════════════════════════════════════════════════════

# Origens permitidas (separa com vírgulas para múltiplas)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ════════════════════════════════════════════════════════════
# UPLOADS
# ════════════════════════════════════════════════════════════

# Tamanho máximo de ficheiro (bytes)
MAX_CONTENT_LENGTH=16777216

# Pasta para uploads
UPLOAD_FOLDER=static/uploads
